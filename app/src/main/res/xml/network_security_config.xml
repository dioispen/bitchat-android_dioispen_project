<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <!-- 替換成你的 ngrok 域名 -->
        <domain includeSubdomains="true">delphine-eisteddfodic-afflictively.ngrok-free.dev</domain>
        <trust-anchors>
            <!-- 信任系統預設憑證 -->
            <certificates src="system" />
            <!-- 信任使用者安裝的憑證 (方便調試) -->
            <certificates src="user" />
        </trust-anchors>
    </domain-config>
</network-security-config>